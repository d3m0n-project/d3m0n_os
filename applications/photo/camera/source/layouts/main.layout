# d3m0n layout

Window:
    title="Camera";
    bg_color="black";
    width="100%";
    height="100%";

Rect:
    name="bottom_bar";
    location="bottom";
    width="100%";
    height="50px";
    bg_color="32, 32, 32";

Image:
    parent="bottom_bar";
    name="gallery";
    src="/themes/default_dark/icons/gallery.bmp";
    location="left";
    width="35px";
    height="35px";

Rect:
    name="shoot";
    parent="bottom_bar";
    location="center";
    width="35px";
    height="35px";
    bg_color="128,128,128";
    radius="25px";
