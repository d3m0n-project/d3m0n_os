# d3m0n layout

Window:
	width="100%";
	height="100%";
	title="Settings";
	bg_color="white";
	topbar="true";

Vscroll:
	bg_color="white";
	name="v1";
	width="100%";
	height="100%";
	location="0, 0";
	bar="true";

Text:
	content="settings";
	location = "0, 5";
	width="100%";
	parent="v1";
	height="50px";

