Window:
	width="100%";
	height="100%";
	title="Settings - About";
	bg_color="black";
	topbar="true";

Vscroll:
	name="v1";
	bar="true";
	width="100%";
	height="450";
	location="0, 30";
	bg_color="black";




# version

Rect:
	name="about_message";
	width="100%";
	height="100px";
	location="0, 500";
	parent="v1";


Text:
	name="kernel_version";
	width="100%";
	height="20px";
	parent="about_message";
	location="0, 0";
	content="2.0.0";
	text_align="center";
	color="237,237,237";

Text:
	name="kernel_version_name";
	width="100%";
	height="20px";
	parent="about_message";
	location="0, 20";
	text_align="center";
	color="237,237,237";
	content="outset";
